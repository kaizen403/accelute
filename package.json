{
  "name": "accelute",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run -r build",
    "db:generate": "pnpm --filter @accelute/db generate",
    "db:migrate": "pnpm --filter @accelute/db migrate",
    "db:push": "pnpm --filter @accelute/db push",
    "lint": "pnpm run -r lint",
    "typecheck": "pnpm run -r typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
