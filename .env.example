# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Database
DATABASE_URL=postgresql://accelute:accelute@localhost:5432/accelute

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=qa-agent-evidence
# Public R2 dev URL for inline video playback (wrangler r2 bucket dev-url enable qa-agent-evidence)
R2_PUBLIC_BASE_URL=

# Clone-and-run
CLONE_TMP_DIR=/tmp/qa-agent-clones
CLONE_AND_RUN_ENABLED=true
ALLOW_FORK_CLONES=false
APP_START_TIMEOUT_MS=90000
INSTALL_TIMEOUT_MS=300000
VIDEO_MAX_SECONDS=60

# App
PUBLIC_BASE_URL=http://localhost:3001
API_PORT=3001
WEB_PORT=3002

# Browser
BROWSER_BACKEND=playwright
CAMOFOX_URL=http://localhost:9377

# Evidence temp dir (local before upload)
EVIDENCE_TMP_DIR=/tmp/qa-agent-evidence
